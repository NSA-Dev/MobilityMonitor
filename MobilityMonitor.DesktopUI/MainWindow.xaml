<Window x:Class="MobilityMonitor.DesktopUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2000/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2000/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="VBN Transit Monitor" Height="600" Width="900">
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#2C3E50" Padding="15">
            <TextBlock Text="VBN ANOMALY DETECTION SYSTEM" Foreground="White" FontSize="18" FontWeight="Bold"/>
        </Border>

        <StatusBar DockPanel.Dock="Bottom" Background="#F0F0F0">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="Initializing..." Foreground="#666666" />
            </StatusBarItem>
        </StatusBar>

        <Grid Margin="10">
            <DataGrid x:Name="AnomalyGrid" 
                      AutoGenerateColumns="True" 
                      IsReadOnly="True" 
                      AlternatingRowBackground="#F9F9F9"/>
        </Grid>
    </DockPanel>
</Window>